{
  "name": "omp-webui",
  "version": "0.1.0",
  "description": "Loopback WebUI extension plugin for Oh My Pi chat sessions.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "extension",
    "shared",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "bun test extension/*.test.ts",
    "prepack": "bun run build"
  },
  "omp": {
    "description": "WebUI for OMP chat, session, project, task, and job state.",
    "extensions": [
      "./extension/index.ts"
    ],
    "settings": {
      "port": {
        "type": "number",
        "description": "Preferred loopback port for the WebUI server. If occupied, the plugin reports and uses a free loopback port.",
        "default": 3848,
        "min": 1,
        "max": 65535,
        "step": 1
      },
      "autoOpen": {
        "type": "boolean",
        "description": "Open the WebUI URL in the system browser when /webui starts the server.",
        "default": true
      },
      "fileTreeMaxFiles": {
        "type": "number",
        "description": "Maximum files/directories returned per file-tree request.",
        "default": 300,
        "min": 10,
        "max": 5000,
        "step": 10
      },
      "filePreviewMaxBytes": {
        "type": "number",
        "description": "Maximum bytes returned by the file preview API.",
        "default": 262144,
        "min": 1024,
        "max": 5242880,
        "step": 1024
      }
    }
  },
  "dependencies": {
    "@oh-my-pi/pi-coding-agent": "^14.5.12",
    "classnames": "^2.5.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
